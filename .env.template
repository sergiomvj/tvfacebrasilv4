# TV FaceBrasil v4 - Environment Variables
#
# Copie este arquivo para `.env` e preencha apenas o que for usar.
# Nunca commitar `.env` com chaves reais.

# ============================================
# APP CONFIG
# ============================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# EXECUTION MODE
# ============================================
# true = modo offline/mock, nao chama APIs reais nem consome creditos.
TVFACEBRASIL_HEYGEN_MOCK=true
TVFACEBRASIL_LLM_MOCK=true

# ============================================
# FACEBRASIL SUPABASE (origem dos artigos)
# ============================================
# Banco da FaceBrasil usado para ler artigos e salvar metadados do video.
FACEBRASIL_SUPABASE_URL=https://your-project.supabase.co
FACEBRASIL_SUPABASE_ANON_KEY=your-anon-key
FACEBRASIL_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FACEBRASIL_SUPABASE_CONNECTION=
FACEBRASIL_SUPABASE_TOKEN=

# ============================================
# TVFACEBRASIL LLM / TEXT GENERATION
# ============================================
# Ordem usada pelo MVP:
# 1. OpenRouter
# 2. OpenAI
# 3. Legacy LLM_API_KEY
TVFACEBRASIL_OPENROUTER_API_KEY=
TVFACEBRASIL_OPENROUTER_MODEL_TEXT=deepseek/deepseek-v4-flash
TVFACEBRASIL_OPENAI_API_KEY=
TVFACEBRASIL_OPENAI_MODEL_TEXT=gpt-4.1-mini

# ============================================
# TVFACEBRASIL HEYGEN (Video generation - producao MVP)
# ============================================
# Conta A - minima para rodar producao real.
TVFACEBRASIL_HEYGEN_A_API_KEY=
TVFACEBRASIL_HEYGEN_A_APP_ID=
TVFACEBRASIL_HEYGEN_A_AVATAR_ID=avatar-1
TVFACEBRASIL_HEYGEN_A_VOICE_ID=voz-masc-ptbr

# Conta B - opcional para round-robin.
TVFACEBRASIL_HEYGEN_B_API_KEY=
TVFACEBRASIL_HEYGEN_B_APP_ID=
TVFACEBRASIL_HEYGEN_B_AVATAR_ID=avatar-2
TVFACEBRASIL_HEYGEN_B_VOICE_ID=voz-fem-ptbr

# ============================================
# TVFACEBRASIL VIDEO PROVIDER LAB (experimental)
# ============================================
# Producao MVP deve ficar em heygen.
# OpenRouter Video fica desligado ate aprovacao explicita.
TVFACEBRASIL_VIDEO_PROVIDER=heygen
TVFACEBRASIL_OPENROUTER_VIDEO_ENABLED=false
TVFACEBRASIL_OPENROUTER_VIDEO_MODEL=bytedance/seedance-2.0
TVFACEBRASIL_OPENROUTER_VIDEO_MODEL2=x-ai/grok-imagine-video
TVFACEBRASIL_OPENROUTER_VIDEO_MODEL3=kwaivgi/kling-v3.0-std
TVFACEBRASIL_OPENROUTER_VIDEO_MODEL4=google/veo-3.1-fast

# ============================================
# OPERATIONAL ALERTS (opcional / futuro)
# ============================================
# Nao usado no MVP atual, reservado para alerta de falha/execucao.
TVFACEBRASIL_TELEGRAM_BOT_TOKEN=
TVFACEBRASIL_TELEGRAM_CHAT_ID=

# ============================================
# LEGACY COMPATIBILITY (temporario)
# ============================================
# O codigo ainda aceita estes nomes antigos como fallback para facilitar migracao.
# Prefira os prefixos FACEBRASIL_* e TVFACEBRASIL_* acima.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_TEXT=
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=
LLM_API_KEY=
LLM_MODEL=
HEYGEN_MOCK=
LLM_MOCK=
HEYGEN_A_API_KEY=
HEYGEN_A_AVATAR_ID=
HEYGEN_A_VOICE_ID=
VIDEO_PROVIDER=
OPENROUTER_VIDEO_ENABLED=
