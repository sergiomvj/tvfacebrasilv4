# TV FaceBrasil v4 - Example Environment
#
# Use `.env.template` as the authoritative template.
# This file stays intentionally short for tools that look for `.env.example`.

NODE_ENV=development
LOG_LEVEL=info

TVFACEBRASIL_HEYGEN_MOCK=true
TVFACEBRASIL_LLM_MOCK=true

FACEBRASIL_SUPABASE_URL=https://your-project.supabase.co
FACEBRASIL_SUPABASE_ANON_KEY=your-anon-key
FACEBRASIL_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

TVFACEBRASIL_OPENROUTER_API_KEY=
TVFACEBRASIL_OPENROUTER_MODEL_TEXT=deepseek/deepseek-v4-flash
TVFACEBRASIL_OPENAI_API_KEY=
TVFACEBRASIL_OPENAI_MODEL_TEXT=gpt-4.1-mini

TVFACEBRASIL_HEYGEN_A_API_KEY=
TVFACEBRASIL_HEYGEN_A_AVATAR_ID=avatar-1
TVFACEBRASIL_HEYGEN_A_VOICE_ID=voz-masc-ptbr

TVFACEBRASIL_VIDEO_PROVIDER=heygen
TVFACEBRASIL_OPENROUTER_VIDEO_ENABLED=false
